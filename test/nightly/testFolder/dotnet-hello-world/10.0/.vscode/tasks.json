{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "publish-release",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "publish",
        "-c",
        "Release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ]
}
